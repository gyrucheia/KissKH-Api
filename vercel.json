{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    },
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.12"
      }
    },
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "main.py"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "dist/client/assets/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "dist/server/server.js"
    }
  ],
  "env": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1"
  }
}
